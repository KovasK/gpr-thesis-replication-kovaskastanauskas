* STEP 1: Prepare Factor Data
*========================================

*--- Fama-French Three Factors ---
* Skip first 4 header rows, parse date as YYYYMM integer
import delimited "FamaFrench3factor_Research_Data_Factors.csv", delimiters(",") rowrange(5:) clear
rename v1 date
rename v2 mktrf
rename v3 smb
rename v4 hml
rename v5 rf
destring date mktrf smb hml rf, replace force
drop if date == .
drop if date > 201912 | date < 198501
gen year     = floor(date / 100)
gen month_num = date - year * 100
gen month    = ym(year, month_num)
format month %tm
drop year month_num date
replace mktrf = mktrf / 100
replace smb   = smb   / 100
replace hml   = hml   / 100
replace rf    = rf    / 100
save "ff3_clean.dta", replace

*--- Carhart Momentum Factor ---
import delimited "F-F_Momentum_Factor.csv", delimiters(",") rowrange(14:) clear
rename v1 date
rename v2 mom
destring date mom, replace force
drop if date == .
drop if date > 201912 | date < 198501
gen year      = floor(date / 100)
gen month_num  = date - year * 100
gen month     = ym(year, month_num)
format month %tm
drop year month_num date
replace mom = mom / 100
save "mom_clean.dta", replace

*--- GPR Index (Caldara & Iacoviello 2022) ---
use "data_gpr_export_stata.dta", clear
keep month GPR GPRT GPRA
keep if month >= monthly("1985m1","YM") & month <= monthly("2019m12","YM")
drop if GPR == .
